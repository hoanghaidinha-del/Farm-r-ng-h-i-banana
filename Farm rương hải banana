local KEY_FILE = "BananaHub_Config.json"
local VALID_KEY = "haidz"

local function SaveKey(key)
    local data = {SavedKey = key, Owner = Player.Name}
    writefile(KEY_FILE, HttpService:JSONEncode(data))
end

local function CheckSavedKey()
    if isfile(KEY_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(KEY_FILE)) end)
        if success and data.SavedKey == VALID_KEY and data.Owner == Player.Name then
            return true
        end
    end
    return false
end

