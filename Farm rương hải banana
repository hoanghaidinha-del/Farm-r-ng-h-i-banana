-- ================= HÀM CHÍNH (START HUB) =================
function StartHub()
    -- Biến toàn cục
    getgenv().AutoFarm = false
    getgenv().FarmMethod = "Tween"
    getgenv().TweenSpeed = 350
    getgenv().UsePortals = true
    getgenv().AntiAdmin = true
    getgenv().AntiAFK = true

    -- [1] HÀM DỊCH CHUYỂN THÔNG MINH
    local function SmartMove(targetCFrame)
        local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        local dist = (root.Position - targetCFrame.Position).Magnitude
        -- Dùng cổng nếu rương quá xa
        if getgenv().UsePortals and dist > 4000 then
            for _, p in pairs(workspace:GetDescendants()) do
                if (p.Name:lower():find("portal") or p.Name:lower():find("teleport")) and p:IsA("BasePart") then
                    if (p.Position - targetCFrame.Position).Magnitude < 1500 then
                        root.CFrame = p.CFrame; task.wait(0.5); break
                    end
                end
            end
        end

        if getgenv().FarmMethod == "Teleport" then
            root.CFrame = targetCFrame
        else
            local d = (root.Position - targetCFrame.Position).Magnitude
            local tween = TweenService:Create(root, TweenInfo.new(d / getgenv().TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
            tween:Play()
            tween.Completed:Wait()
        end
    end

    -- [2] NOCLIP CHỈ KHI FARM
    RunService.Stepped:Connect(function()
        if getgenv().AutoFarm and Player.Character then
            for _, v in pairs(Player.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end)

    -- [3] UI CHÍNH (FIXED TABS)
    if game.CoreGui:FindFirstChild("Hai8aHub") then game.CoreGui.Hai8aHub:Destroy() end
    local Gui = Instance.new("ScreenGui", game.CoreGui); Gui.Name = "Hai8aHub"
    local Main = Instance.new("Frame", Gui); Main.Size = UDim2.new(0, 520, 0, 350); Main.Position = UDim2.new(0.5, -260, 0.5, -175); Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Color3.fromRGB(255, 215, 0)

    -- Nút Quả Chuối 🍌
    local Icon = Instance.new("TextButton", Gui); Icon.Size = UDim2.new(0, 60, 0, 60); Icon.Position = UDim2.new(0.02, 0, 0.4, 0); Icon.Text = "🍌"; Icon.TextSize = 35; Icon.BackgroundColor3 = Color3.fromRGB(255, 215, 0); Instance.new("UICorner", Icon).CornerRadius = UDim.new(1, 0)
    Icon.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

    -- Sidebar & Tab Container
    local Sidebar = Instance.new("Frame", Main); Sidebar.Size = UDim2.new(0, 140, 1, 0); Sidebar.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", Sidebar)
