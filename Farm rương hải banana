-- ================= LOGIC NHẶT RƯƠNG CHO MOBILE =================
local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

task.spawn(function()
    while task.wait(0.2) do -- Delay 0.2 để tránh lag điện thoại
        if getgenv().AutoFarm then
            local root = getRoot()
            if root then
                for _, obj in pairs(workspace:GetDescendants()) do
                    if not getgenv().AutoFarm then break end
                    
                    local name = obj.Name:lower()
                    if name:find("chest") or name:find("rương") or name:find("treasure") then
                        local target = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true)
                        
                        if target and target.Parent then
                            -- TELEPORT (Sử dụng CFrame để không bị kẹt Mobi)
                            root.CFrame = target.CFrame + Vector3.new(0, 3, 0)
                            
                            pcall(function()
                                -- Giả lập chạm
                                firetouchinterest(root, target, 0)
                                firetouchinterest(root, target, 1)
                                
                                -- Tự kích hoạt nút nhặt (Cho Mobi)
                                for _, p in pairs(obj:GetDescendants()) do
                                    if p:IsA("ProximityPrompt") then
                                        -- Mobi cần kích hoạt liên tục để tránh delay
                                        task.spawn(function()
                                            fireproximityprompt(p)
                                        end)
                                    end
                                end
                            end)
                            task.wait(0.4) -- Mobi cần nghỉ lâu hơn PC một chút để render
                        end
                    end
                end
            end
        end
    end
end)

