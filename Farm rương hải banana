    -- Tab Server Fixed
    local SLabel = Instance.new("TextLabel", ServerTab); SLabel.Size = UDim2.new(1, -10, 1, 0); SLabel.BackgroundTransparency = 1; SLabel.TextColor3 = Color3.new(1,1,1); SLabel.TextXAlignment = "Left"; SLabel.TextYAlignment = "Top"; SLabel.Font = "Gotham"; SLabel.TextSize = 13; SLabel.TextWrapped = true
