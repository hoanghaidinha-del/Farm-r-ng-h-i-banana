-- ================= HÀM HỖ TRỢ FARM =================
local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

-- Vòng lặp Farm chạy ngầm (Fixed: Không gây lag UI)
task.spawn(function()
    while task.wait(0.1) do
        if getgenv().AutoFarm then
            local root = getRoot()
            if root then
                -- Tìm kiếm mục tiêu hiệu quả hơn
                for _, obj in pairs(workspace:GetDescendants()) do
                    if not getgenv().AutoFarm then break end
                    
                    -- Kiểm tra tên rương (Chest)
                    if obj:IsA("Model") and (string.find(obj.Name:lower(), "chest") or string.find(obj.Name:lower(), "rương")) then
                        local part = obj:FindFirstChildWhichIsA("BasePart") or obj:FindFirstChild("HumanoidRootPart")
                        
                        if part then
                            -- Teleport thẳng tới rương
                            root.CFrame = part.CFrame + Vector3.new(0, 2, 0)
                            
                            -- Kích hoạt nhặt đồ
                            pcall(function()
                                firetouchinterest(root, part, 0)
                                firetouchinterest(root, part, 1)
                                
                                -- Quét thêm ProximityPrompt nếu có
                                for _, p in pairs(obj:GetDescendants()) do
                                    if p:IsA("ProximityPrompt") then
                                        fireproximityprompt(p)
                                    end
                                end
                            end)
                            task.wait(0.2) -- Delay nhỏ để server nhận diện
                        end
                    end
                end
            end
        end
    end
end)

