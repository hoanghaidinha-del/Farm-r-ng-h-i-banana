getgenv().AutoFarm = false
getgenv().AntiAFK = true

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- ================= HÀM QUÉT VÀ NHẶT (FIXED) =================
local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

task.spawn(function()
    while task.wait(0.1) do
        if getgenv().AutoFarm then
            local root = getRoot()
            if root then
                -- Quét rộng hơn để tìm rương
                for _, v in pairs(workspace:GetDescendants()) do
                    if not getgenv().AutoFarm then break end
                    
                    -- KIỂM TRA: Tên chứa "Chest", "Rương", "Treasure" hoặc có Class là ProximityPrompt/Touch
                    local isChest = false
                    if v:IsA("Model") or v:IsA("BasePart") or v:IsA("Folder") then
                        local name = v.Name:lower()
                        if name:find("chest") or name:find("rương") or name:find("treasure") or name:find("box") then
                            isChest = true
                        end
                    end

                    if isChest then
                        -- Tìm Part để Teleport tới
                        local target = v:IsA("BasePart") and v or v:FindFirstChildWhichIsA("BasePart", true)
                        
                        if target and target.Parent then
                            -- TELEPORT TỚI
                            root.CFrame = target.CFrame + Vector3.new(0, 3, 0)
                            
                            -- NHẶT (Dùng nhiều cách để chắc chắn nhặt được)
                            pcall(function()
                                -- 1. Chạm vào
                                firetouchinterest(root, target, 0)
                                firetouchinterest(root, target, 1)
                                
                                -- 2. Kích hoạt ProximityPrompt (Nếu có)
                                for _, p in pairs(v:GetDescendants()) do
                                    if p:IsA("ProximityPrompt") then
                                        fireproximityprompt(p)
                                    end
                                end
                                
                                -- 3. Click (Nếu có ClickDetector)
                                local cd = v:FindFirstChildWhichIsA("ClickDetector", true)
                                if cd then fireclickdetector(cd) end
                            end)
                            
                            task.wait(0.3) -- Nghỉ 1 chút để rương biến mất rồi mới tìm cái tiếp theo
                        end
                    end
                end
            end
        end
    end
end)

