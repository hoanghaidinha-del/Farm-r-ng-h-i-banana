local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- === CẤU HÌNH KEY ===
local KeyList = {
    ["haidz"] = "Vô thời hạn", -- Key vĩnh viễn của bạn
    ["banana_free"] = "05/03/2026"
}

-- === BIẾN HỆ THỐNG FARM ===
_G_AutoChest = false
_G_Method = "Bay (An toàn)" 
_G_Speed = 200
local Player = game.Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

-- === HÀM DI CHUYỂN TỔNG HỢP ===
local function moveToTarget(targetCFrame)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not _G_AutoChest then return end

    if _G_Method == "Teleport (Nhanh)" then
        root.CFrame = targetCFrame * CFrame.new(0, 3, 0)
        task.wait(0.15)
    else
        local dist = (root.Position - targetCFrame.p).Magnitude
        local tween = TweenService:Create(root, TweenInfo.new(dist/_G_Speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame * CFrame.new(0, 3, 0)})
        tween:Play()
        tween.Completed:Wait()
    end
end

-- === HÀM SERVER HOP ===
local function serverHop()
    local Api = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    local success, res = pcall(function() return game:GetService("HttpService"):JSONDecode(game:HttpGet(Api)) end)
    if success then
        for _, v in pairs(res.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, v.id, Player)
                return
            end
        end
    end
end

-- === KHỞI TẠO MENU CHÍNH (SAU KHI NHẬP KEY) ===
function startMainScript()
    -- 1. Tạo Nút Tròn Vàng (Floating Button)
    if CoreGui:FindFirstChild("HaiBananaGui") then CoreGui.HaiBananaGui:Destroy() end
    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.Name = "HaiBananaGui"
    local ToggleBtn = Instance.new("ImageButton", ScreenGui)
    local Corner = Instance.new("UICorner", ToggleBtn)

    ToggleBtn.Size = UDim2.new(0, 55, 0, 55)
    ToggleBtn.Position = UDim2.new(0.1, 0, 0.15, 0)
    ToggleBtn.Image = "rbxassetid://6031289435"
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    ToggleBtn.Draggable = true 
    ToggleBtn.Active = true
    Corner.CornerRadius = UDim.new(1, 0)

    ToggleBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(CoreGui:GetChildren()) do
            if v.Name:find("Rayfield") and v:FindFirstChild("Main") then
                v.Main.Visible = not v.Main.Visible
                break
            end
        end
    end)

    -- 2. Tạo Menu Farm
    local MainWin = Rayfield:CreateWindow({
       Name = "HAI BANANA CHEST 🍌",
       LoadingTitle = "Đang mở Menu Farm...",
       LoadingSubtitle = "Chào mừng haidz quay trở lại!",
       ConfigurationSaving = { Enabled = false }
    })

    local MainTab = MainWin:CreateTab("Tự động", 4483362458)
    
    MainTab:CreateDropdown({
       Name = "Chế độ di chuyển",
       Options = {"Bay (An toàn)", "Teleport (Nhanh)"},
       CurrentOption = "Bay (An toàn)",
       Callback = function(Option) _G_Method = Option end,
    })

    MainTab:CreateToggle({
       Name = "Auto Farm Rương (3 Sea)",
       CurrentValue = false,
       Callback = function(Value)
          _G_AutoChest = Value
          if Value then
              spawn(function()
                  while _G_AutoChest do
                      local found = false
                      for _, v in pairs(game.Workspace:GetDescendants()) do
                          if not _G_AutoChest then break end
                          if v:IsA("TouchTransmitter") and v.Parent.Name:find("Chest") then
                              found = true
                              moveToTarget(v.Parent.CFrame)
                              task.wait(0.2)
                          end
                      end
                      if not found then serverHop() break end
                      task.wait(1)
                  end
              end)
          end
       end,
    })

    MainTab:CreateButton({ Name = "Nhảy Server", Callback = function() serverHop() end })

    local ConfigTab = MainWin:CreateTab("Cài đặt", 4483362458)
    ConfigTab:CreateSlider({
       Name = "Tốc độ bay",
       Range = {100, 350},
       Increment = 10,
       CurrentValue = 200,
       Callback = function(Value) _G_Speed = Value end,
    })

    -- 3. Bảo vệ chạy ngầm
    spawn(function()
        while task.wait(3) do
            -- Anti-Admin
            for _, p in pairs(game.Players:GetPlayers()) do
                if p:GetRankInGroup(2830050) >= 250 or p.Name:find("Admin") then serverHop() end
            end
            -- Anti-AFK
            game:GetService("VirtualUser"):CaptureController()
            game:GetService("VirtualUser"):ClickButton2(Vector2.new())
        end
    end)
end

