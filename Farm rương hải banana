                        if not table.find(bosses, m.Name) then table.insert(bosses, m.Name) end
                    end
                end
                SLabel.Text = string.format("🏝️ Sea: %s\n💰 Rương: %d\n👹 Boss hiện có:\n• %s", (game.PlaceId == 2753915549 and "1" or game.PlaceId == 4442245410 and "2" or "3"), chests, #bosses > 0 and table.concat(bosses, "\n• ") or "Trống")
            end)
        end
    end)

    -- [5] VÒNG LẶP FARM CHÍNH
    task.spawn(function()
        while task.wait(0.1) do
            if getgenv().AutoFarm then
                pcall(function()
                    for _, v in pairs(workspace:GetDescendants()) do
                        if not getgenv().AutoFarm then break end
                        if v.Name:lower():find("chest") then
                            local t = v:IsA("BasePart") and v or v:FindFirstChildWhichIsA("BasePart", true)
                            if t and t.Transparency < 0.7 then
