-- ================= HÀM QUÉT DỮ LIỆU SERVER =================
local function GetServerDetails()
    local chestCount = 0
    local fruitFound = "Không có"
    local bosses = {}
    local currentIsland = "Đang quét..."

    -- 1. Quét Rương và Trái cây
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name:lower():find("chest") or v.Name:lower():find("rương") then
            chestCount = chestCount + 1
        end
        if v:IsA("Tool") and (v.Name:find("Fruit") or v:FindFirstChild("Handle")) then
            fruitFound = v.Name
        end
    end

    -- 2. Quét Boss
    local enemies = workspace:FindFirstChild("Enemies") or workspace
    for _, npc in pairs(enemies:GetChildren()) do
        if npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
            if npc.Humanoid.MaxHealth >= 50000 or npc:FindFirstChild("BossLabel") then
                table.insert(bosses, npc.Name)
            end
        end
    end

    -- 3. Xác định Đảo
    local loc = workspace:FindFirstChild("Locations")
    if loc and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = Player.Character.HumanoidRootPart.Position
        local closestDist = math.huge
        for _, zone in pairs(loc:GetChildren()) do
            local d = (myPos - zone.Position).Magnitude
            if d < closestDist then
                closestDist = d
                currentIsland = zone.Name
            end
        end
    end

    local bossList = #bosses > 0 and table.concat(bosses, "\n• ") or "Đã bị diệt hết"
    return chestCount, fruitFound, bossList, currentIsland
end

-- ================= GIAO DIỆN CHÍNH =================
function StartBananaHub()
    getgenv().AutoFarm = false
    
    local Gui = Instance.new("ScreenGui", game.CoreGui)
    Gui.Name = "Hai8aHub"

    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 480, 0, 320)
    Main.Position = UDim2.new(0.5, -240, 0.5, -160)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", Main)
    Instance.new("UIStroke", Main).Color = Color3.fromRGB(255, 215, 0)

    -- Sidebar (Thanh bên)
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 130, 1, 0)
    Sidebar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", Sidebar)
    
    local UIList = Instance.new("UIListLayout", Sidebar)
    UIList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    UIList.Padding = UDim.new(0, 5)

    local Title = Instance.new("TextLabel", Sidebar)
    Title.Size = UDim2.new(1, 0, 0, 50)
    Title.Text = "HẢI8A 🍌"
    Title.TextColor3 = Color3.fromRGB(255, 215, 0)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 20
    Title.BackgroundTransparency = 1

    -- Container chứa các Tab
    local Container = Instance.new("Frame", Main)
    Container.Position = UDim2.new(0, 140, 0, 10)
    Container.Size = UDim2.new(1, -150, 1, -20)
    Container.BackgroundTransparency = 1

    -- Hàm tạo Tab
    local tabs = {}
    local function CreateTab(name, active)
        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = active
        Page.ScrollBarThickness = 2
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)

        local Btn = Instance.new("TextButton", Sidebar)
        Btn.Size = UDim2.new(0.9, 0, 0, 35)
        Btn.Text = name
        Btn.BackgroundColor3 = active and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(30, 30, 30)
        Btn.TextColor3 = active and Color3.new(0,0,0) or Color3.new(1,1,1)
        Btn.Font = Enum.Font.GothamBold
        Instance.new("UICorner", Btn)

        Btn.MouseButton1Click:Connect(function()
            for _, t in pairs(tabs) do t.Page.Visible = false t.Btn.BackgroundColor3 = Color3.fromRGB(30,30,30) t.Btn.TextColor3 = Color3.new(1,1,1) end
            Page.Visible = true
            Btn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
            Btn.TextColor3 = Color3.new(0,0,0)
        end)
        tabs[name] = {Page = Page, Btn = Btn}
        return Page
    end

    -- KHỞI TẠO TABS
    local FarmTab = CreateTab("Farm", true)
    local ServerTab = CreateTab("Server", false)

    -- [NỘI DUNG TAB FARM]
    local FarmBtn = Instance.new("TextButton", FarmTab)
    FarmBtn.Size = UDim2.new(1, 0, 0, 45)
    FarmBtn.Text = "AUTO FARM CHEST: OFF"
    FarmBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    FarmBtn.TextColor3 = Color3.new(1,1,1)
    FarmBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", FarmBtn)

    FarmBtn.MouseButton1Click:Connect(function()
        getgenv().AutoFarm = not getgenv().AutoFarm
        FarmBtn.Text = "AUTO FARM CHEST: " .. (getgenv().AutoFarm and "ON" or "OFF")
        FarmBtn.BackgroundColor3 = getgenv().AutoFarm and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
    end)

    -- [NỘI DUNG TAB SERVER]
    local ServerLabel = Instance.new("TextLabel", ServerTab)
    ServerLabel.Size = UDim2.new(1, 0, 1, 0)
    ServerLabel.BackgroundTransparency = 1
    ServerLabel.TextColor3 = Color3.new(1, 1, 1)
    ServerLabel.TextXAlignment = Enum.TextXAlignment.Left
    ServerLabel.TextYAlignment = Enum.TextYAlignment.Top
    ServerLabel.Font = Enum.Font.Gotham
    ServerLabel.TextSize = 14
    ServerLabel.Text = "Đang tải dữ liệu server..."

    -- Cập nhật Tab Server mỗi 3 giây
    task.spawn(function()
        while task.wait(3) do
            if ServerTab.Visible then
                local c, f, b, i = GetServerDetails()
                ServerLabel.Text = string.format(
                    "🏝️ ĐẢO: %s\n\n👹 BOSS ĐANG CÓ:\n• %s\n\n💰 RƯƠNG HIỆN TẠI: %d\n🍎 TRÁI CÂY RƠI: %s\n\n--------------------------\n⏱️ Server Time: %s",
                    i, b, c, f, os.date("%X")
                )
            end
        end
    end)

    -- [HỆ THỐNG AUTO NOCLIP & FARM TWEEN GIỮ NGUYÊN]
end

