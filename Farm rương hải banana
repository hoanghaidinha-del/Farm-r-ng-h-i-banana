-- ================= HÀM DI CHUYỂN =================
local function SafeMove(targetCFrame)
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Noclip xuyên mọi thứ
    for _, v in pairs(Player.Character:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    if getgenv().FarmMethod == "Teleport" then
        root.CFrame = targetCFrame
    else
        local distance = (root.Position - targetCFrame.Position).Magnitude
        if distance < 5 then root.CFrame = targetCFrame return end
        
        local tween = TweenService:Create(root, TweenInfo.new(distance / getgenv().TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    end
end

-- ================= LOGIC FARM (QUÉT MỌI LOẠI RƯƠNG) =================
task.spawn(function()
    while task.wait(0.3) do
        if getgenv().AutoFarm then
            pcall(function()
                local Root = Player.Character:FindFirstChild("HumanoidRootPart")
                if not Root then return end

                local AllChests = {}
                -- Quét rộng hơn để không bỏ sót bất kỳ rương nào ở Sea 1, 2, 3
                for _, v in pairs(game.Workspace:GetDescendants()) do
                    if v:IsA("BasePart") and (v.Name:lower():find("chest") or v.Name:lower():find("rương")) then
                        -- Loại bỏ rương đã mở (thường rương mở rồi sẽ bị xóa hoặc có tên khác, nhưng ta check kĩ)
                        if v.Parent and v.Parent.Name ~= "Opened" then
                            table.insert(AllChests, {
                                Part = v,
                                Dist = (Root.Position - v.Position).Magnitude
                            })
                        end
                    end
                end

                -- SẮP XẾP ƯU TIÊN GẦN NHẤT
                table.sort(AllChests, function(a, b) return a.Dist < b.Dist end)

                -- Bắt đầu hành trình nhặt rương
                for i = 1, #AllChests do
                    if not getgenv().AutoFarm then break end
                    local target = AllChests[i].Part
                    
                    if target and target.Parent then
                        -- Bay đến rương
                        SafeMove(target.CFrame + Vector3.new(0, 2, 0))
                        
                        -- Chạm rương (Dùng cả 2 cách để chắc chắn server nhận)
                        firetouchinterest(Root, target, 0)
                        task.wait()
                        firetouchinterest(Root, target, 1)
                        
                        -- Nhấn giữ E (Cho Sea 2, 3 và rương hiếm)
                        local prompt = target:FindFirstChildOfClass("ProximityPrompt") or target.Parent:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then fireproximityprompt(prompt) end
                        
                        task.wait(0.1) -- Nghỉ cực ngắn để chuyển rương tiếp theo
                    end
                end
            end)
        end
    end
end)

