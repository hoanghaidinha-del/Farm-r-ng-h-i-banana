local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

local function moveTo(cf)
    local root = getRoot()
    if not root or not _G.AutoChest then return end

    if _G.Method == "Teleport (Nhanh)" then
        root.CFrame = cf * CFrame.new(0,3,0)
        task.wait(0.15)
    else
        local dist = (root.Position - cf.Position).Magnitude
        local tween = TweenService:Create(
            root,
            TweenInfo.new(dist/_G.Speed, Enum.EasingStyle.Linear),
            {CFrame = cf * CFrame.new(0,3,0)}
        )
        tween:Play()
        tween.Completed:Wait()
    end
end

local function serverHop()
    local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
    local s,res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(Api))
    end)
    if s then
        for _,v in pairs(res.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId,v.id,Player)
                break
            end
        end
    end
end

