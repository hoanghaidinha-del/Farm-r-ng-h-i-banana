})

MainTab:CreateToggle({
   Name = "Bật Auto Farm Rương",
   CurrentValue = false,
   Callback = function(v)
      _G.AutoChest = v
      if v then
          spawn(function()
              while _G.AutoChest do
                  local found = false
                  for _,x in pairs(workspace:GetDescendants()) do
                      if not _G.AutoChest then break end
                      if x:IsA("TouchTransmitter") and x.Parent.Name:find("Chest") then
                          found = true
                          moveTo(x.Parent.CFrame)
                          task.wait(0.1)
                      end
                  end
                  if not found then
                      Rayfield:Notify({
                          Title="Hết rương",
                          Content="Đang nhảy server...",
                          Duration=3
                      })
                      serverHop()
                      break
                  end
                  task.wait(1)
              end
          end)
      end
   end,
})

