    local Title = Instance.new("TextLabel", Sidebar); Title.Size = UDim2.new(1,0,0,50); Title.Text = "HẢI8A 🍌"; Title.TextColor3 = Color3.fromRGB(255,215,0); Title.Font = "GothamBold"; Title.BackgroundTransparency = 1

    local PageContainer = Instance.new("Frame", Main); PageContainer.Position = UDim2.new(0, 150, 0, 10); PageContainer.Size = UDim2.new(1, -160, 1, -20); PageContainer.BackgroundTransparency = 1

    local function CreateTab(name, active)
        local P = Instance.new("ScrollingFrame", PageContainer); P.Size = UDim2.new(1, 0, 1, 0); P.Visible = active; P.BackgroundTransparency = 1; P.ScrollBarThickness = 2; P.AutomaticCanvasSize = "Y"
        Instance.new("UIListLayout", P).Padding = UDim.new(0, 8)
        
        local B = Instance.new("TextButton", Sidebar); B.Size = UDim2.new(0.9, 0, 0, 40); B.Text = name; B.BackgroundColor3 = active and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(35, 35, 35); B.TextColor3 = active and Color3.new(0,0,0) or Color3.new(1,1,1); B.Font = "GothamBold"; Instance.new("UICorner", B)
        
        B.MouseButton1Click:Connect(function()
            for _, v in pairs(PageContainer:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, t in pairs(Sidebar:GetChildren()) do if t:IsA("TextButton") then t.BackgroundColor3 = Color3.fromRGB(35, 35, 35); t.TextColor3 = Color3.new(1,1,1) end end
            P.Visible = true; B.BackgroundColor3 = Color3.fromRGB(255, 215, 0); B.TextColor3 = Color3.new(0,0,0)
        end)
        return P
    end

    local FarmTab = CreateTab("Farm", true)
    local ServerTab = CreateTab("Server", false)
    local AntiTab = CreateTab("Anti", false)
    local MethodTab = CreateTab("Methods", false)

    -- [4] CHỨC NĂNG CÁC TAB
    local function AddToggle(p, text, val, def)
        local b = Instance.new("TextButton", p); b.Size = UDim2.new(1, 0, 0, 45); b.BackgroundColor3 = def and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(35,35,35); b.Text = text..": "..(def and "ON" or "OFF"); b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamBold"; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            getgenv()[val] = not getgenv()[val]
