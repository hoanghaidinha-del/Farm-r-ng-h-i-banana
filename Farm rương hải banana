local function AddMethod(name)
    local b = Instance.new("TextButton", MethodTab)
    b.Size = UDim2.new(1, 0, 0, 40)
    b.Text = "Mode: " .. name
    b.BackgroundColor3 = (getgenv().FarmMethod == name) and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(30, 30, 30)
    b.TextColor3 = (getgenv().FarmMethod == name) and Color3.new(0,0,0) or Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        getgenv().FarmMethod = name
        for _, btn in pairs(MethodTab:GetChildren()) do if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30) btn.TextColor3 = Color3.new(1,1,1) end end
        b.BackgroundColor3 = Color3.fromRGB(255, 215, 0) b.TextColor3 = Color3.new(0,0,0)
    end)
end

