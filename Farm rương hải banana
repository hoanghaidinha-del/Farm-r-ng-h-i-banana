local _K = "haidz" -- Key vĩnh viễn
local _A = Player.UserId -- Khóa tài khoản duy nhất

-- ================= GIAO DIỆN LOGIN =================
if game.CoreGui:FindFirstChild("BananaLogin") then game.CoreGui.BananaLogin:Destroy() end
