-- ================= HÀM HỖ TRỢ (UTILITIES) =================
local function SendNotify(title, text, duration)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title;
        Text = text;
        Duration = duration or 3;
        Icon = "rbxassetid://6031289232"; -- Icon Pro
    })
end

local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

-- ================= THUẬT TOÁN FARM TỐI ƯU =================
local function startFarming()
    SendNotify("HẢI8A PRO", "Đã bắt đầu Farm Rương!", 3)
    
    while Config.AutoFarm do
        local root = getRoot()
        if not root then task.wait(1) continue end

        -- Quét thông minh (Chỉ quét các Part có khả năng là rương)
        for _, obj in pairs(workspace:GetDescendants()) do
            if not Config.AutoFarm then break end
            
            local isTarget = false
            for _, name in pairs(Config.TargetNames) do
                if string.find(obj.Name, name) then
                    isTarget = true
                    break
                end
            end

            if isTarget and obj:IsA("BasePart") or (obj:IsA("Model") and obj:FindFirstChildWhichIsA("BasePart")) then
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                
                -- Kiểm tra khoảng cách để tránh lag
                if (root.Position - targetPart.Position).Magnitude < Config.FarmDistance then
                    
                    -- Teleport mượt (CFrame)
                    root.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
                    
                    -- Kích hoạt mọi loại tương tác
                    pcall(function()
                        firetouchinterest(root, targetPart, 0)
                        firetouchinterest(root, targetPart, 1)
                        
                        -- Quét Prompt/Click bên trong
                        for _, v in pairs(obj:GetDescendants()) do
                            if v:IsA("ProximityPrompt") then fireproximityprompt(v) end
                            if v:IsA("ClickDetector") then fireclickdetector(v) end
                        end
                    end)
                    
                    task.wait(0.1) -- Nghỉ ngắn để server nhận diện nhặt đồ
                end
            end
        end
        task.wait(0.5)
    end
end

