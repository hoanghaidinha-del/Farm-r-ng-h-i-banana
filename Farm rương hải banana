-- ================= SERVICES =================
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- ================= VARIABLES =================
local AutoFarm = false
local FarmSpeed = 300

local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

-- ================= TELEPORT MƯỢT =================
local function smoothTeleport(cf)
    local root = getRoot()
    if not root then return end

    local dist = (root.Position - cf.Position).Magnitude
    local time = math.clamp(dist / FarmSpeed, 0.03, 0.3)

    local tween = TweenService:Create(
        root,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = cf * CFrame.new(0,3,0)}
    )
    tween:Play()
    tween.Completed:Wait()
end

-- ================= AUTO NHẬN DIỆN RƯƠNG =================
local function isChestModel(model)
    if not model then return false end
    if model:FindFirstChildWhichIsA("TouchTransmitter", true) then return true end
    if model:FindFirstChildWhichIsA("ProximityPrompt", true) then return true end
    if model:FindFirstChildWhichIsA("ClickDetector", true) then return true end
    return false
end

local function getNearestChest()
    local root = getRoot()
    if not root then return end

    local nearest
    local shortest = math.huge

    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and isChestModel(obj) then
            local part = obj:FindFirstChildWhichIsA("BasePart")
            if part then
                local dist = (root.Position - part.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    nearest = part
                end
            end
        end
    end

    return nearest
end

local function collectChest(part)
    local root = getRoot()
    if not root then return end

    root.CFrame = part.CFrame + Vector3.new(0,3,0)

    pcall(function()
        firetouchinterest(root, part, 0)
        firetouchinterest(root, part, 1)
    end)

    for _,v in pairs(part.Parent:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            fireproximityprompt(v)
        end
        if v:IsA("ClickDetector") then
            fireclickdetector(v)
        end
    end
end

local function farmLoop()
    while AutoFarm do
        local chest = getNearestChest()
        if chest then
            smoothTeleport(chest.CFrame)
            task.wait(0.05)
            collectChest(chest)
        else
            task.wait(1)
        end
        task.wait(0.1)
    end
end

